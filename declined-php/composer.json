{
  "name": "declined/sdk",
  "description": "Official Declined.io REST API client for PHP",
  "type": "library",
  "license": "MIT",
  "version": "1.0.0",
  "authors": [{ "name": "Declined.io" }],
  "require": {
    "php": ">=8.1",
    "guzzlehttp/guzzle": "^7.9",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Declined\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Declined\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}
